# ── Supabase ──────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Meta WhatsApp Cloud API (primary customer channel) ────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=pick-a-random-string-and-paste-into-meta-console

# ── Instagram Graph API (DMs + comments) ──────────────────────────────
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_VERIFY_TOKEN=pick-another-random-string

# ── Razorpay (UPI-first payment links + webhook) ──────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Razorpay Dashboard → Webhooks → URL: <backend>/webhooks/razorpay
#   event: payment_link.paid
RAZORPAY_WEBHOOK_SECRET=

# ── Slack ops alerts ──────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Lead & Quote agent (Claude) ───────────────────────────────────────
# Without a key the agent degrades to a holding message + Slack alert.
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-sonnet-5
# Needed for Instagram DM replies (IG business account user id)
INSTAGRAM_USER_ID=

# ── Business rules ────────────────────────────────────────────────────
# Hard cap on events per day (also capped by active decorator count).
DAILY_EVENT_CAPACITY=2
# Provisional hold lifetime after a quote is sent (hours).
HOLD_TTL_HOURS=2
# Paid booking without full vendor acceptance past the escalation window
# → customer proactively offered refund-or-reschedule. Base window (hours);
# actual window scales with event distance: ≤7 days out → 12h, ≤30 days → 24h,
# further → 48h.
VENDOR_ESCALATION_HOURS=24
# Advance collected to lock a booking (fraction of quote total, 25-30% per site)
ADVANCE_PERCENT=0.30

# ── Misc ──────────────────────────────────────────────────────────────
GOOGLE_REVIEW_LINK=
PORT=8000
