# ═══════════════════════════════════════════════════════════
# Twilio WhatsApp — get from https://console.twilio.com
# ═══════════════════════════════════════════════════════════
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your Twilio WhatsApp sender number (sandbox: whatsapp:+14155238886)
# Production: whatsapp:+91XXXXXXXXXX (your approved business number)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ═══════════════════════════════════════════════════════════
# Owner / admin — where new-booking + new-lead alerts are sent
# Also receives the 07:30 IST daily digest (today/tomorrow's events,
# pending leads & approvals, month's pipeline).
# ═══════════════════════════════════════════════════════════
OWNER_WHATSAPP=whatsapp:+918867121207

# Max events the bot will book on any single date before telling
# customers that date is full and offering the next open ones.
DAILY_BOOKING_CAPACITY=2

# Below-floor price asks within this % of the floor are auto-approved
# without waking you (still logged + a quiet FYI sent to you). Asks further
# below than this still escalate and wait for approve/reject. 0.05 = 5%.
AUTO_APPROVE_BAND=0.05

# ═══════════════════════════════════════════════════════════
# Proactive lead outreach (auto-message customers who submit the website form)
# ═══════════════════════════════════════════════════════════
# Shared secret — must match BOT_LEAD_TOKEN in js/main.js. Blocks abuse of /lead.
LEAD_WEBHOOK_TOKEN=change-me-to-a-random-string

# Shared secret for /missed-call — set this as the auth token/header value
# in your call-tracking service's webhook config (Exotel/Knowlarity/etc.).
MISSED_CALL_TOKEN=change-me-to-a-random-string

# Approved Twilio Content template SID for the business-initiated opener.
# REQUIRED in production to message a lead who hasn't texted first (Meta rule).
# Leave blank in sandbox — bot falls back to a plain message.
# Template body suggestion (vars {{1}}=name {{2}}=service):
#   "Hello {{1}}, this is Shiva from Flowers 'N' Balloons. Thank you for your
#    interest in {{2}} — I'd love to plan it for you. What date is your event?"
LEAD_TEMPLATE_SID=

# ═══════════════════════════════════════════════════════════
# Server
# ═══════════════════════════════════════════════════════════
PORT=3000

# Public HTTPS URL of this server (ngrok / Railway / Render domain).
# Used to verify Twilio signatures AND to attach PDF invoices. Leave blank for local dev.
PUBLIC_URL=

# ═══════════════════════════════════════════════════════════
# Razorpay payment links (OPTIONAL — leave blank to disable)
# Dashboard → Settings → API Keys
# ═══════════════════════════════════════════════════════════
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret: Razorpay Dashboard → Settings → Webhooks → add
#   URL: <PUBLIC_URL>/razorpay/webhook  · events: payment_link.paid
RAZORPAY_WEBHOOK_SECRET=

# ═══════════════════════════════════════════════════════════
# Google Sheets sync (OPTIONAL — leave blank to disable)
# See lib/sheets.js header for the 4-step setup
# ═══════════════════════════════════════════════════════════
# Path to the service-account JSON key file (or paste the raw JSON)
GOOGLE_SERVICE_ACCOUNT_JSON=
# Sheet ID from its URL: docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=Bookings

# Timezone for reminders (IST)
TZ=Asia/Kolkata

# Public website URL — used to serve sample photos to WhatsApp (packages/gallery).
# Must be publicly reachable HTTPS so Twilio can fetch the images. Blank = no photos.
SITE_URL=https://www.flowersnballoons.com

# ═══════════════════════════════════════════════════════════
# AI price negotiation (OPTIONAL). When set, the bot bargains like Shiva
# using Claude. Never quotes below 15% off. Blank = scripted negotiator.
# Get a key at https://console.anthropic.com
# ═══════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=
